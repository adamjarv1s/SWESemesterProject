{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES6",                // or later
    "module": "ESNext",             // or "CommonJS" depending on your setup
    "jsx": "react-jsx",             // for React 17+ (or "react" for older versions)
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
